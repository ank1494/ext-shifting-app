{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/dev/ext-shifting-app/.claude/hooks/protect-main-edits.sh\""
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/dev/ext-shifting-app/.claude/hooks/protect-main-commits.sh\""
          }
        ]
      }
    ]
  }
}
